{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Clothing items sold on the store"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "suits",
        "shirts",
        "shoes",
        "accessories",
        "african_attires"
      ],
      "required": true
    },
    "badge": {
      "type": "string",
      "default": ""
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text"
    }
  }
}
