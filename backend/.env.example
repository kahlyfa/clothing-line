# ── Strapi Core ────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified

# ── Database (PostgreSQL) ───────────────────────────────────
# DigitalOcean App Platform injects these automatically from the db add-on.
# For local dev, fill in your local Postgres credentials.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=franko_clothing
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_SSL=false

# ── DigitalOcean Spaces (file uploads) ─────────────────────
# Create a Space in your DO account, then create an API key under
# API → Spaces Keys. Set your Space region (e.g. nyc3, sfo3, ams3).
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=franko-clothing-media
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key

# CDN endpoint (enable CDN on the Space in DO dashboard first)
# Format: https://BUCKET.REGION.cdn.digitaloceanspaces.com
CDN_URL=https://franko-clothing-media.nyc3.cdn.digitaloceanspaces.com

# ── Frontend origin (for CORS) ──────────────────────────────
# Comma-separated list of allowed frontend URLs
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:5500,https://your-app.ondigitalocean.app
